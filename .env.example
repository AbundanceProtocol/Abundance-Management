# MongoDB (required for app data)
MONGODB_URI=mongodb://localhost:27017/abundance-strategy

# Auth — set a long random string (32+ characters)
AUTH_SECRET=replace-with-a-long-random-secret-string

# Login password for full edit access at /
APP_PASSWORD=your-secure-password

# Local dev only: set to "true" to skip login and API auth (never in production)
# SKIP_AUTH=true
